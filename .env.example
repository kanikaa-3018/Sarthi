NODE_ENV=development
PORT=8000

# Use your MongoDB Atlas connection string here.
# Example:
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=sarthi

AUTH_SECRET=change-this-before-sharing
SEED_ON_START=false
DEMO_CONTROLS_ENABLED=true
EXTERNAL_SERVICE_TIMEOUT_MS=8000

# Optional Neo4j evidence graph projection. Keep disabled unless Neo4j is running.
NEO4J_ENABLED=false
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# Optional Atlas Vector Search over evidence embeddings.
# Requires MongoDB Atlas vector search index on VECTOR_SEARCH_COLLECTION:
# path: embedding, dimensions: EMBEDDING_DIMENSIONS, similarity: cosine
VECTOR_SEARCH_ENABLED=false
VECTOR_SEARCH_COLLECTION=evidence_embeddings
VECTOR_SEARCH_INDEX=sarthi_evidence_vector
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=768

# Optional grounded answer generation and confidence assignment.
# Supported provider in this repo: gemini
LLM_PROVIDER=gemini
LLM_MODEL=gemini-3.1-flash-lite
GEMINI_API_KEY=
