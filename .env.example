NODE_ENV=development
PORT=8000

# Use your MongoDB Atlas connection string here.
# Example:
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=sarthi

AUTH_SECRET=change-this-before-sharing
SEED_ON_START=false
DEMO_CONTROLS_ENABLED=true
EXTERNAL_SERVICE_TIMEOUT_MS=8000

# Optional Neo4j evidence graph projection. Keep disabled unless Neo4j is running.
NEO4J_ENABLED=false
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# Optional semantic retrieval over evidence embeddings.
# On MongoDB Atlas this uses Atlas Vector Search. On local MongoDB, enabling it
# uses provider-specific embeddings with local cosine similarity inside the API.
# Titan (512) and Gemini (768) always use separate collections and indexes.
VECTOR_SEARCH_ENABLED=false
BEDROCK_VECTOR_SEARCH_COLLECTION=evidence_embeddings_bedrock
BEDROCK_VECTOR_SEARCH_INDEX=sarthi_evidence_vector_bedrock_512
VECTOR_SEARCH_COLLECTION=evidence_embeddings
VECTOR_SEARCH_INDEX=sarthi_evidence_vector
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=768

# Bedrock-first AI. BEDROCK_ENABLED is an explicit cost-safety gate. The SDK
# uses the normal AWS credential chain; never place AWS access keys in this file.
AI_PROVIDER_ORDER=bedrock,gemini
BEDROCK_ENABLED=false
AWS_REGION=ap-south-1
AWS_DEFAULT_REGION=ap-south-1
BEDROCK_TEXT_MODELS=apac.amazon.nova-micro-v1:0,apac.amazon.nova-lite-v1:0
BEDROCK_VISION_MODELS=apac.amazon.nova-lite-v1:0
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0
BEDROCK_EMBEDDING_DIMENSIONS=512

# Gemini remains the automatic fallback when its key is present.
# These legacy names continue to configure the Gemini adapter.
LLM_PROVIDER=gemini
LLM_MODEL=gemini-3.1-flash-lite
GEMINI_API_KEY=
