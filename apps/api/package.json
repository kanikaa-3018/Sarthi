{
  "name": "sarthi-api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/tsx/dist/cli.mjs watch src/server.ts",
    "build": "node ./node_modules/typescript/bin/tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "seed": "node ./node_modules/tsx/dist/cli.mjs src/scripts/seed.ts",
    "gemini:smoke": "node ./node_modules/tsx/dist/cli.mjs src/scripts/geminiSmoke.ts",
    "vector:index": "node ./node_modules/tsx/dist/cli.mjs src/scripts/createVectorIndex.ts",
    "test": "node ./node_modules/tsx/dist/cli.mjs --test src/tests/*.test.ts",
    "typecheck": "node ./node_modules/typescript/bin/tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1090.0",
    "@fastify/cors": "^11.0.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "mongodb": "^6.12.0",
    "neo4j-driver": "^5.28.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
