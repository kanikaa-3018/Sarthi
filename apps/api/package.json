{
  "name": "sarthi-api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "seed": "tsx src/scripts/seed.ts",
    "vector:index": "tsx src/scripts/createVectorIndex.ts",
    "test": "tsx --test src/tests/trust-rbac.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "mongodb": "^6.12.0",
    "neo4j-driver": "^5.28.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
